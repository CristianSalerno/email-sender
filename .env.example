# SendGrid (required to send)
SENDGRID_API_KEY=
FROM_EMAIL=

# Single-client app login (required in production)
APP_LOGIN_PASSWORD=
SESSION_SECRET=

# Supabase (optional — without these, contacts are parsed in memory only and sends are not logged)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=contact-uploads

# Vercel Cron: optional secret to protect /api/keepalive (Vercel sends Bearer token automatically)
CRON_SECRET=

# Gemini AI (optional — free tier at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Local server
PORT=3000
